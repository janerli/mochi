# Copy to .env and fill in with your Supabase project's values.
# Settings → Database → Connection string (URI) in the Supabase dashboard
# gives you both of these — the pooled one (port 6543) for DATABASE_URL, the
# direct one (port 5432) for DIRECT_URL (Prisma migrations need a real
# session, not a pooled connection).
DATABASE_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-xxxxx.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-xxxxx.pooler.supabase.com:5432/postgres"

PORT=4000
# Generate your own with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="mochi-dev-secret-change-me"

# Settings → API in the Supabase dashboard.
SUPABASE_URL="https://xxxxx.supabase.co"
# The "service_role" key, NOT the "anon" key — this one bypasses RLS and must
# never be exposed to the browser. Only ever used server-side in storage.ts.
SUPABASE_SERVICE_KEY="eyJ..."
SUPABASE_BUCKET="attachments"
